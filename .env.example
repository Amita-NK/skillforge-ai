# SkillForge AI+ Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# AWS Configuration (Required for AI Service)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ============================================================================
# Amazon Bedrock Configuration
# ============================================================================
# Supported models:
# - anthropic.claude-v2
# - anthropic.claude-v2:1
# - anthropic.claude-instant-v1
# - amazon.titan-text-express-v1
# - meta.llama2-70b-chat-v1
BEDROCK_MODEL_ID=anthropic.claude-v2

# ============================================================================
# OpenSearch Configuration (Optional - for RAG pipeline)
# ============================================================================
OPENSEARCH_HOST=your-opensearch-endpoint.region.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_opensearch_password
OPENSEARCH_INDEX=skillforge-docs

# ============================================================================
# Backend Configuration
# ============================================================================
# Flask secret keys (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Flask environment (development, production)
FLASK_ENV=development

# Backend server port
PORT=5000

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite (for development)
DATABASE_URL=sqlite:///skillforge.db

# MySQL (for production)
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/skillforge

# PostgreSQL (alternative)
# DATABASE_URL=postgresql://username:password@localhost:5432/skillforge

# MySQL Docker configuration (if using docker-compose with MySQL)
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=skillforge
# MYSQL_USER=skillforge
# MYSQL_PASSWORD=password

# ============================================================================
# Service URLs (for inter-service communication)
# ============================================================================
# AI Service URL (used by backend)
AI_SERVICE_URL=http://localhost:8000

# Backend URL (used by frontend)
BACKEND_URL=http://localhost:5000

# ============================================================================
# Frontend Configuration (when implemented)
# ============================================================================
# REACT_APP_API_URL=http://localhost:5000
# REACT_APP_ENV=development

# ============================================================================
# AWS Deployment Configuration (for production)
# ============================================================================
# AWS_ACCOUNT_ID=123456789012
# AWS_ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
# AWS_ECS_CLUSTER=skillforge-cluster
# AWS_RDS_ENDPOINT=skillforge-db.xxxxx.us-east-1.rds.amazonaws.com
# AWS_OPENSEARCH_ENDPOINT=search-skillforge-xxxxx.us-east-1.es.amazonaws.com

# ============================================================================
# Logging Configuration
# ============================================================================
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# ============================================================================
# Security Configuration
# ============================================================================
# JWT token expiration (in hours)
# JWT_ACCESS_TOKEN_EXPIRES=24

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================================================
# Feature Flags
# ============================================================================
# ENABLE_RAG=true
# ENABLE_ANALYTICS=false
# ENABLE_RATE_LIMITING=true

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit .env file to version control
# 2. Use strong, unique values for SECRET_KEY and JWT_SECRET_KEY in production
# 3. Ensure AWS credentials have appropriate Bedrock permissions
# 4. For production, use managed database services (RDS, Aurora)
# 5. Enable HTTPS in production environments
# 6. Rotate secrets regularly
