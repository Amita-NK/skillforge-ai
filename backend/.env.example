# ============================================================================
# SkillForge Backend Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values
# All variables marked as REQUIRED must be set for the service to start

# Flask Configuration (REQUIRED)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
FLASK_ENV=development

# Database Configuration (REQUIRED)
# For MySQL/MariaDB (production):
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/skillforge
# For SQLite (development):
# DATABASE_URL=sqlite:///skillforge.db

# AI Service Configuration (REQUIRED)
AI_SERVICE_URL=http://localhost:8000

# Server Configuration (Optional)
PORT=5000

# ============================================================================
# Notes:
# - DATABASE_URL: Connection string for the database
#   Format: dialect+driver://username:password@host:port/database
# - SECRET_KEY: Used for Flask session management and CSRF protection
# - JWT_SECRET_KEY: Used for signing JWT authentication tokens
# - AI_SERVICE_URL: URL where the AI microservice is running
# ============================================================================
